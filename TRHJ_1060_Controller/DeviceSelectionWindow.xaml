<Window x:Class="TRHJ_1060_Controller.DeviceSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TRHJ Controller - Выбор устройства" 
        Height="365" Width="500"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="TRHJ Controller" 
                   FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <!-- Выбор COM порта -->
        <GroupBox Grid.Row="1" Header="Подключение" Margin="0,0,0,15">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="COM порт:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox x:Name="CmbPorts" Width="150" Margin="0,0,10,0"/>
                    <Button x:Name="BtnRefreshPorts" Content="Обновить" Width="80" Click="BtnRefreshPorts_Click"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="BtnConnect" Content="Подключиться" 
                            Width="120" Margin="0,0,10,0" 
                            Click="BtnConnect_Click"/>
                    <Button x:Name="BtnDisconnect" Content="Отключиться" 
                            Width="120" IsEnabled="False"
                            Click="BtnDisconnect_Click"/>
                </StackPanel>
                <TextBlock Grid.Row="2" x:Name="TxtConnectionStatus" 
                               Text="Статус: Не подключено" 
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
            </Grid>
        </GroupBox>
        
        <!-- Выбор типа чипа -->
        <GroupBox Grid.Row="2" Header="Тип устройства" Margin="0,0,0,15">
            <StackPanel Margin="10" Orientation="Horizontal">
                <ComboBox x:Name="CmbChipType" Width="430" Margin="0,0,10,0" SelectionChanged="CmbChipType_SelectionChanged"/>
            </StackPanel>
        </GroupBox>
        
        <!-- Кнопка продолжить -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="BtnContinue" Content="Продолжить →" 
                    Width="150" Height="40" 
                    FontSize="14" FontWeight="Bold"
                    IsEnabled="False"
                    Click="BtnContinue_Click"/>
        </StackPanel>
    </Grid>
</Window>